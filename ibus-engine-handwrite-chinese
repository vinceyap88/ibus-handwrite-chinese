        engine_language = "zh"
        component_name = "com.github.vinceyap88.ibus-handwrite-chinese-traditional"
        ZINNIA_MODEL = "/usr/share/tegaki/models/zinnia/handwriting-zh_TW.model"
        ZINNIA_MODEL_BACKUP = None
        _USE_FREQ = False
    else:
        engine_name = "handwrite-chinese-simplified"
        engine_longname = "Chinese Handwriting (Simplified)"
        engine_language = "zh"
        component_name = "com.github.vinceyap88.ibus-handwrite-chinese-simplified"
        ZINNIA_MODEL = ZINNIA_MODEL_LILY
        ZINNIA_MODEL_BACKUP = "/usr/share/tegaki/models/zinnia/handwriting-zh_CN.model"
        _USE_FREQ = False

    Gtk.init(sys.argv)
