        self._drag_y = 0
        self.candidate_buttons = []
        self._last_redraw = 0.0
        self._min_redraw_ms = 16
        self._state = 0
        self._blank_cursor = Gdk.Cursor.new(Gdk.CursorType.BLANK_CURSOR)
        self._trackpad = None
        self._cand_page = 0
        self._page_size = 8
        self._delete_timer = None
        self._delete_held = False

        self.connect("key-press-event", self.on_key)
        self.connect("button-press-event", self.on_window_click)

    def start_trackpad(self):
        if not EVDEV_AVAILABLE:
            return False
        self._trackpad = handwrite_evdev.TrackpadReader({
            'on_stroke_begin': self.on_trackpad_begin,
            'on_stroke_point': self.on_trackpad_point,
            'on_stroke_end': self.on_trackpad_end,
            'on_tap': self.on_trackpad_tap,
            'on_swipe_left': self.on_trackpad_swipe_left,
            'on_swipe_right': self.on_trackpad_swipe_right,
        })
        return self._trackpad.start()

    def stop_trackpad(self):
        if self._trackpad:
            self._trackpad.stop()
            self._trackpad = None

    def on_key_esc(self):
        self._write_log('on_key_esc: _state=%d' % self._state)
        if self._state == 0:
            self._state = 1
            self.stop_trackpad()
            self._restore_cursor()
            self.darea.queue_draw()
            self.queue_draw()
            self.show_candidates([])
            self.close_btn.show()
        else:
            self._do_reset()
            self._do_disable()
            self.engine.restore_previous_engine()

    def on_close_click(self, btn=None):
        self._do_reset()
        self._do_disable()
        self.engine.restore_previous_engine()

    def on_key(self, w, ev):
        name = Gdk.keyval_name(ev.get_keyval()[1])
        if name == "Escape":
            self.on_key_esc()
            return True
        if name == "Return":
            self.engine.commit_first()
            return True
        if name == "BackSpace":
            self.on_delete_tap(None)
            return True
        return False

    def on_window_click(self, widget, ev):
        if self._state == 1:
            self._state = 0
            self.darea.queue_draw()
            self.close_btn.hide()
            self.start_trackpad()
            self.engine.update_candidates()
            self._hide_cursor()
        return False

    def _hide_cursor(self):
        gw = self.get_window()
        if gw:
            gw.set_cursor(self._blank_cursor)

    def _restore_cursor(self):
        gw = self.get_window()
        if gw:
            gw.set_cursor(None)

    def _do_reset(self):
        self.strokes = []
        self.cur_stroke = []
        self.pix = None
        self.queue_draw()
        self.show_candidates([])
        self.engine.zinnia.clear()
        if hasattr(self.engine, "zinnia_backup") and self.engine.zinnia_backup:
            self.engine.zinnia_backup.clear()
        self.engine.last_results = []

    def _do_disable(self):
        self.stop_trackpad()
        self._restore_cursor()
        self.hide()
        self._state = 0

    def _do_clear_strokes(self):
        self.strokes.clear()
        self.engine.zinnia.clear()
        self.engine.zinnia.stroke_id = 0
        if hasattr(self.engine, "zinnia_backup") and self.engine.zinnia_backup:
            self.engine.zinnia_backup.clear()
            self.engine.zinnia_backup.stroke_id = 0
        self.pix = None
        self.queue_draw()
        self.engine.update_candidates()

    def _do_forward_backspace(self):
        GLib.spawn_command_line_async("/usr/bin/xdotool key --delay 0 BackSpace") 

    def on_delete_tap(self, btn=None):
        if self._delete_held:
            self._delete_held = False
            return
        has_strokes = bool(self.strokes) or bool(self.cur_stroke)
        self._do_clear_strokes()
        if not has_strokes:
            self._do_forward_backspace()

    def on_delete_press(self, btn, ev):
        self._delete_held = False
        if self._delete_timer:
            GLib.source_remove(self._delete_timer)
        self._delete_timer = GLib.timeout_add(500, self._on_delete_hold_timeout)
        return False

    def _on_delete_hold_timeout(self):
        self._delete_held = True
        self._do_clear_strokes()
        self._do_forward_backspace()
        return False

    def on_delete_release(self, btn, ev):
        if self._delete_timer:
            GLib.source_remove(self._delete_timer)
            self._delete_timer = None

    def show_candidates(self, results):
        for btn in self.candidate_buttons:
            btn.destroy()
        self.candidate_buttons = []
        if not results:
            self._cand_page = 0
            return
        total = len(results)
        max_page = (total - 1) // self._page_size
        if self._cand_page > max_page:
            self._cand_page = max_page
        start = self._cand_page * self._page_size
        end = start + self._page_size
        for i, (val, score) in enumerate(results[start:end]):
            actual_idx = start + i
            btn = Gtk.Button(label=val)
            btn.get_style_context().add_class("candidate-btn")
            btn.set_can_focus(False)
            btn.set_size_request(36, -1)
            btn.connect("clicked", lambda b, idx=actual_idx: self.engine.pick_candidate(idx))
            self.cand_inner.pack_start(btn, False, False, 0)
            self.candidate_buttons.append(btn)
        self.cand_inner.show_all()

    def _pixel_coords(self, frac_x, frac_y):
        alloc = self.darea.get_allocation()
        return (frac_x * alloc.width, frac_y * alloc.height)

    def _throttle_redraw(self):
        t = time.time() * 1000
        if t - self._last_redraw >= self._min_redraw_ms:
            self.queue_draw()
            self._last_redraw = t

    def on_trackpad_begin(self, frac_x, frac_y):
        px, py = self._pixel_coords(frac_x, frac_y)
        self.drawing = True
        self.cur_stroke = [(px, py)]

    def on_trackpad_point(self, frac_x, frac_y):
        if not self.drawing:
            return
        px, py = self._pixel_coords(frac_x, frac_y)
        self.cur_stroke.append((px, py))
        self._throttle_redraw()

    def on_trackpad_end(self, points_frac):
        if not points_frac:
            self.drawing = False
            return
        alloc = self.darea.get_allocation()
        pixel_pts = [(fx * alloc.width, fy * alloc.height) for fx, fy in points_frac]
        self.drawing = False
        self.strokes.append(pixel_pts)
        self.engine.zinnia.add_stroke(pixel_pts)
        self.cur_stroke = []
        self.pix = None
        self.queue_draw()
        self.engine.update_candidates()

    def on_trackpad_tap(self, x_frac):
        if x_frac > 0.7:
            self.on_delete_tap(None)
            return
        num = len(self.engine.last_results)
        if num > 0:
            start = self._cand_page * self._page_size
            visible = min(self._page_size, num - start)
            if visible > 0:
                idx = min(start + int(x_frac * visible), num - 1)
                self.engine.pick_candidate(idx)

    def on_trackpad_swipe_left(self):
        total = len(self.engine.last_results)
        if total > 0:
            max_page = (total - 1) // self._page_size
            self._cand_page = min(self._cand_page + 1, max_page)
            self.show_candidates(self.engine.last_results)

    def on_trackpad_swipe_right(self):
        total = len(self.engine.last_results)
        if total > 0:
            self._cand_page = max(self._cand_page - 1, 0)
            self.show_candidates(self.engine.last_results)

    def rebuild_pix(self, ww, hh):
        import cairo
        self.pix = cairo.ImageSurface(cairo.FORMAT_ARGB32, ww, hh)
        cr = cairo.Context(self.pix)
        cr.set_source_rgb(0.15, 0.15, 0.17)
        cr.paint()
        cr.set_source_rgb(1, 1, 1)
        cr.set_line_width(3)
        cr.set_line_cap(cairo.LINE_CAP_ROUND)
        cr.set_line_join(cairo.LINE_JOIN_ROUND)
        cr.set_antialias(cairo.ANTIALIAS_BEST)
        for stroke in self.strokes:
            if len(stroke) < 2:
                continue
            cr.move_to(stroke[0][0], stroke[0][1])
            for pt in stroke[1:]:
                cr.line_to(pt[0], pt[1])
            cr.stroke()

    def on_btn_down(self, w, ev):
        self.drawing = True
        self.cur_stroke = [(ev.x, ev.y)]

    def on_move(self, w, ev):
        if self.drawing and (ev.state & Gdk.ModifierType.BUTTON1_MASK):
            self.cur_stroke.append((ev.x, ev.y))
            self._throttle_redraw()

    def on_btn_up(self, w, ev):
        if not self.drawing:
            return
        self.drawing = False
        if self.cur_stroke:
            self.cur_stroke.append((ev.x, ev.y))
            self.strokes.append(self.cur_stroke)
            self.engine.zinnia.add_stroke(self.cur_stroke)
            self.cur_stroke = []
            self.pix = None
        self.queue_draw()
        self.engine.update_candidates()

    def on_draw(self, w, cr):
        alloc = self.darea.get_allocation()
        ww, hh = alloc.width, alloc.height
        if self._state == 1:
            cr.set_source_rgba(0, 0, 0, 0.5)
            cr.rectangle(0, 0, ww, hh)
            cr.fill()
            cr.set_source_rgb(1, 1, 1)
            cr.select_font_face("Sans", cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_BOLD)
            cr.set_font_size(30)
            text = "click to resume"
            xb = cr.text_extents(text)
            box_w, box_h = xb.width + 40, xb.height + 30
            cr.rectangle((ww - box_w) / 2, (hh - box_h) / 2, box_w, box_h)
            cr.set_source_rgba(0, 0, 0, 0.6)
            cr.fill()
            # Shadow for visibility
            cr.set_source_rgb(0, 0, 0)
            cr.move_to((ww - xb.width) / 2 + 2, (hh - xb.height) / 2 + 22)
            cr.show_text(text)
            cr.set_source_rgb(1, 1, 1)
            cr.move_to((ww - xb.width) / 2, (hh - xb.height) / 2 + 20)
            cr.show_text(text)
            return
        if self.pix is None:
            self.rebuild_pix(ww, hh)
        cr.set_source_surface(self.pix, 0, 0)
        cr.paint()
        if self.cur_stroke and len(self.cur_stroke) > 1:
            import cairo
            cr.set_source_rgb(1, 1, 1)
            cr.set_line_width(3)
            cr.set_line_cap(cairo.LINE_CAP_ROUND)
            cr.set_line_join(cairo.LINE_JOIN_ROUND)
            cr.set_antialias(cairo.ANTIALIAS_BEST)
            cr.move_to(self.cur_stroke[0][0], self.cur_stroke[0][1])
            for pt in self.cur_stroke[1:]:
                cr.line_to(pt[0], pt[1])
            cr.stroke()

    def on_draw_handle(self, widget, cr):
        alloc = widget.get_allocation()
        cr.set_source_rgb(0.2, 0.2, 0.2)
        cr.rectangle(0, 0, alloc.width, alloc.height)
        cr.fill()
        cr.set_source_rgb(0.5, 0.5, 0.5)
        cx = alloc.width / 2
        for i in range(5):
            x = cx + (i - 2) * 10
            cr.arc(x, alloc.height / 2, 2, 0, 6.2832)
            cr.fill()

    def on_drag_begin(self, widget, ev):
        self._drag_x = ev.x_root
        self._drag_y = ev.y_root

    def on_drag_end(self, widget, ev):
        pass

    def on_drag_move(self, widget, ev):
        if ev.state & Gdk.ModifierType.BUTTON1_MASK:
            dx = int(ev.x_root - self._drag_x)
            dy = int(ev.y_root - self._drag_y)
            if dx or dy:
                px, py = self.get_position()
                self.move(px + dx, py + dy)
                self._drag_x = ev.x_root
                self._drag_y = ev.y_root

    def destroy(self):
        self.stop_trackpad()
        if self._delete_timer:
            GLib.source_remove(self._delete_timer)
            self._delete_timer = None
        self.pix = None
        Gtk.Window.destroy(self)


class HandwriteEngine(IBus.Engine):
    def __init__(self):
        super().__init__()
        self.zinnia = ZinniaHandle(ZINNIA_MODEL)
        self.zinnia_backup = None
        if ZINNIA_MODEL_BACKUP:
            try:
                self.zinnia_backup = ZinniaHandle(ZINNIA_MODEL_BACKUP)
            except:
                pass
        self.win = None
        self.last_results = []
        self._bus = None
        self._watch_id = None
        self._cx = 0
        self._cy = 0
        self._cw = 0
        self._ch = 0
        self._engine_name = None

    def do_process_key_event(self, keyval, keycode, state):
        self._write_log('do_pke: keyval=%d visible=%s' % (keyval, str(self.win.get_visible() if self.win else False)))
        if state & IBus.ModifierType.RELEASE_MASK:
            return super().do_process_key_event(keyval, keycode, state)
        if keyval in (IBus.KEY_Escape, IBus.KEY_BackSpace, IBus.KEY_Return) and self.win and self.win.get_visible():
            if keyval == IBus.KEY_Escape:
                self.win.on_key_esc()
            elif keyval == IBus.KEY_BackSpace:
                self.win._do_clear_strokes()
                return False
            elif keyval == IBus.KEY_Return:
                self.commit_first()
            return True
        return super().do_process_key_event(keyval, keycode, state)

    def do_set_cursor_location(self, x, y, w, h):
        self._cx = x
        self._cy = y
        self._cw = w
        self._ch = h
        if self.win and self.win.get_visible():
            self._position_window()

    def _position_window(self):
        if not self.win:
            return
        wx = self._cx
        wy = self._cy + self._ch + 4
        screen = Gdk.Screen.get_default()
        mw = screen.get_width()
        mh = screen.get_height()
        win_w = 400
        win_h = 360
        wx = max(0, min(wx, mw - win_w))
        wy = max(0, min(wy, mh - win_h))
        self.win.move(int(wx), int(wy))

    def do_enable(self):
        self._write_log('do_enable')
        if self.win is None:
            self.win = HandwriteWin(self)
        if self._bus is None:
            self._bus = IBus.Bus()
        self.win._state = 0

        current = self._bus.get_global_engine()
        if current:
            self._engine_name = current.get_name()
        self.zinnia.clear()
        if self.zinnia_backup:
            self.zinnia_backup.clear()
        self.last_results = []
        self.win.show_all()
        self.win.close_btn.hide()
        self._position_window()
        self.win.present()
        self.win._hide_cursor()
        self.win.start_trackpad()
        if self._watch_id is None:
            self._watch_id = GLib.timeout_add(500, self._check_engine)

    def do_disable(self):
        if self._watch_id:
            GLib.source_remove(self._watch_id)
            self._watch_id = None
        if self.win:
            self.win._restore_cursor()
            self.win.stop_trackpad()
        if self.win:
            self.win.hide()
        self.zinnia.clear()
        if self.zinnia_backup:
            self.zinnia_backup.clear()
        self.last_results = []

    def restore_previous_engine(self):
        if not self._bus:
            return
        try:
            settings = Gio.Settings.new('org.freedesktop.ibus.general')
            engines = settings.get_strv('preload-engines')
            for name in engines:
                if name and name != self._engine_name:
                    self._bus.set_global_engine(name)
                    return
        except Exception:
            pass
        try:
            self._bus.set_global_engine('xkb:us::eng')
        except Exception:
            pass

    def _write_log(self, msg):
        import os
        with open('/tmp/hw.log', 'a') as _f:
            _f.write(str(os.getpid()) + ' ' + msg + '\n')

    def do_focus_out(self):
        pass

    def _check_engine(self):
        if self._bus and self.win:
            current = self._bus.get_global_engine()
            if current and current.get_name() != self._engine_name:
                if self.win.get_visible():
                    self.win.hide()
                self._watch_id = None
                return False
        return True

    def do_reset(self):
        if self.win:
            self.win._do_reset()
        self.zinnia.clear()
        if self.zinnia_backup:
            self.zinnia_backup.clear()
        self.last_results = []

    def update_candidates(self):
        results = self.zinnia.classify()
        if not results and self.zinnia_backup and self.zinnia.all_points:
            self.zinnia_backup.all_points = list(self.zinnia.all_points)
            self.zinnia_backup.stroke_id = self.zinnia.stroke_id
            results = self.zinnia_backup.classify()
        self.last_results = results
        if self.win:
            self.win.show_candidates(results)

    def commit_first(self):
        if self.last_results:
            self.commit_text(IBus.Text.new_from_string(self.last_results[0][0]))
            self.do_reset()

    def pick_candidate(self, idx):
        if idx < len(self.last_results):
            self.commit_text(IBus.Text.new_from_string(self.last_results[idx][0]))
            self.do_reset()

    def destroy(self):
        if self.win:
            self.win.destroy()
            self.win = None
        if self.zinnia:
            self.zinnia.destroy()
            self.zinnia = None
        if hasattr(self, "zinnia_backup") and self.zinnia_backup:
            self.zinnia_backup.destroy()
            self.zinnia_backup = None
        super().destroy()


GObject.type_register(HandwriteEngine)


