class ZinniaHandle:
    def __init__(self, model_path):
        self.ptr = libz.zinnia_recognizer_new()
        if not self.ptr:
            raise RuntimeError("Failed to create zinnia recognizer")
        ret = libz.zinnia_recognizer_open(self.ptr, model_path.encode())
        if not ret:
            err = libz.zinnia_recognizer_strerror(self.ptr)
            libz.zinnia_recognizer_destroy(self.ptr)
            raise RuntimeError(f"Failed to open model: {err.decode() if err else 'unknown'}")
        self.character = None
        self.stroke_id = 0
        self.all_points = []

    def clear(self):
        if self.character:
            libz.zinnia_character_destroy(self.character)
        self.character = None
        self.stroke_id = 0
        self.all_points = []

    def add_stroke(self, points):
        self.all_points.append(points)
        self.stroke_id += 1

    def classify(self):
        if not self.all_points:
            return []
        if self.character:
            libz.zinnia_character_destroy(self.character)
        self.character = libz.zinnia_character_new()
        libz.zinnia_character_clear(self.character)
        libz.zinnia_character_set_width(self.character, 1000)
        libz.zinnia_character_set_height(self.character, 1000)

        flat = [pt for stroke in self.all_points for pt in stroke]
        if not flat:
            return []
        xs = [p[0] for p in flat]
        ys = [p[1] for p in flat]
        xmin, xmax = min(xs), max(xs)
        ymin, ymax = min(ys), max(ys)
        cw = max(xmax - xmin, 1)
        ch = max(ymax - ymin, 1)
        scale = min((1000 - 100) / cw, (1000 - 100) / ch)
        cx = (xmin + xmax) / 2
        cy = (ymin + ymax) / 2

        for sid, stroke in enumerate(self.all_points):
            for x, y in stroke:
                nx = int(500 + (x - cx) * scale)
                ny = int(500 + (y - cy) * scale)
                nx = max(0, min(1000, nx))
                ny = max(0, min(1000, ny))
                libz.zinnia_character_add(self.character, sid, nx, ny)

        result_ptr = libz.zinnia_recognizer_classify(self.ptr, self.character, MAX_CANDIDATES * 4)
        if not result_ptr:
            return []
        size = libz.zinnia_result_size(result_ptr)
        raw = []
        for i in range(size):
            val = libz.zinnia_result_value(result_ptr, i)
            score = libz.zinnia_result_score(result_ptr, i)
            if val:
                raw.append((val.decode('utf-8'), score))
        libz.zinnia_result_destroy(result_ptr)

        ranked = []
        seen = set()
        for ch, sc in raw:
            if ch in seen:
                continue
            seen.add(ch)
            if _USE_FREQ:
                boost = _FREQ.get(ch, -2.0)
            else:
                boost = 0.0
            ranked.append((ch, sc + 0.5 * boost))
        ranked.sort(key=lambda x: -x[1])
        return [(ch, sc) for ch, sc in ranked]

    def destroy(self):
        if self.character:
            libz.zinnia_character_destroy(self.character)
            self.character = None
        if self.ptr:
            libz.zinnia_recognizer_destroy(self.ptr)
            self.ptr = None


